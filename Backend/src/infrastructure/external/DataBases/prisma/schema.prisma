generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model user{
    id                  String @id @default(uuid())
    correo              String
    name                String
    last_name           String
    password            String
    phone               String
    emergency_contact   String?
    two_factor_auth     DateTime?
    role_id             Int
    role                Role @relation(fields:[role_id], references:[id])
    created_at          DateTime
    updated_at          DateTime
}

model Role{
  id                  Int @id @default(autoincrement())
  role_name           String 
  users               user[]
  description         String
  permissions_id      Int 
  permission          Permission @relation(fields: [permissions_id], references: [id])
  created_at          DateTime
}

model Permission{
  id                  Int @id @default(autoincrement())
  name                String
  roles               Role[]
  description         String
}

